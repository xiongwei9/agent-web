{
  "name": "@ai-chat/agui-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fastify AG-UI server with OpenAPI and Zod schemas.",
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "dev": "pnpm --filter @ai-chat/agents build && node --watch src/index.ts",
    "build": "pnpm --filter @ai-chat/agents build && tsc -p tsconfig.json",
    "typecheck": "pnpm --filter @ai-chat/agents build && tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@ag-ui/core": "0.0.53",
    "@ag-ui/encoder": "0.0.53",
    "@ai-chat/agents": "workspace:*",
    "@fastify/cors": "^11.0.1",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.6.0",
    "fastify-type-provider-zod": "^4.0.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.2"
  }
}
