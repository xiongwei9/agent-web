{
  "name": "@ai-chat/agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agent provider registry and AG-UI agent runners.",
  "engines": {
    "node": ">=22.13.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "compile": "tsc -p tsconfig.json",
    "copy:agents": "mkdir -p dist/agents/definitions && cp src/agents/definitions/*.md dist/agents/definitions/",
    "copy:skills": "mkdir -p dist/skills && find src/skills -mindepth 1 -maxdepth 1 -type d -exec cp -R {} dist/skills/ ';'",
    "copy:assets": "npm run copy:agents && npm run copy:skills",
    "build": "npm run clean && npm run compile && npm run copy:assets",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.53",
    "@ag-ui/core": "0.0.53",
    "@ag-ui/mastra": "^1.0.3",
    "@ai-sdk/anthropic": "^2.0.79",
    "@ai-sdk/google": "^2.0.74",
    "@ai-sdk/openai": "^3.0.66",
    "@mastra/client-js": "^1.21.1",
    "@mastra/core": "^1.37.1",
    "@mastra/libsql": "^1.11.1",
    "@mastra/memory": "^1.20.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "rxjs": "7.8.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.2"
  }
}
