# URL the browser POSTs AG-UI runs to. Defaults to the dev proxy path "/agui"
# (see vite.config.ts), which forwards to VITE_AGUI_TARGET. Set an absolute URL
# here to talk to a remote server directly (the server enables CORS).
VITE_AGUI_URL=/agui

# Dev-only: where the Vite proxy forwards "/agui" requests.
VITE_AGUI_TARGET=http://localhost:3000
